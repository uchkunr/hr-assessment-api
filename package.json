{
  "name": "hr-assessment-api",
  "version": "0.0.1",
  "description": "HR Candidate Screening API Gateway built with Elysia and Prisma",
  "private": true,
  "module": "src/index.ts",
  "author": {
    "name": "Uchkun Rakhimov",
    "email": "uchkunrakhimov@gmail.com",
    "url": "https://github.com/uchkunr"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/uchkunr/hr-assessment-api.git"
  },
  "bugs": {
    "url": "https://github.com/uchkunr/hr-assessment-api/issues"
  },
  "homepage": "https://github.com/uchkunr/hr-assessment-api#readme",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "build": "bunx prisma generate && bun build --compile --minify-whitespace --minify-syntax --outfile server src/index.ts",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\" \"*.{ts,json,md}\"",
    "format:check": "prettier --check \"src/**/*.ts\" \"*.{ts,json,md}\""
  },
  "dependencies": {
    "@elysiajs/cors": "^1.4.2",
    "@elysiajs/jwt": "^1.4.2",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "elysia": "1.4.29",
    "nodemailer": "^9.0.3",
    "pino": "^10.3.1",
    "prismabox": "^1.1.26",
    "puppeteer": "^25.2.1"
  },
  "devDependencies": {
    "@types/nodemailer": "^8.0.1",
    "bun-types": "^1.3.14",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.4.2",
    "prisma": "^7.8.0",
    "typescript-eslint": "^8.16.0"
  },
  "overrides": {
    "@hono/node-server": "^1.19.13"
  },
  "allowScripts": {
    "prisma": true,
    "puppeteer": true,
    "@prisma/engines": true
  }
}
